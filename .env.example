# Config Watch - Environment Variable Reference
# All config keys can be set via CONFIG_WATCH_ prefix environment variables.
# Copy this file to .env and fill in values for your local development setup.

# ── Control Plane ──────────────────────────────────────────────────────

# Required: Postgres connection string
CONFIG_WATCH_DATABASE_URL=postgres://postgres:postgres@localhost:5432/config_watch

# Required: HMAC secret for agent token verification (>=32 chars in production)
CONFIG_WATCH_CONTROL_PLANE_SECRET=dev-only-secret-change-me-in-production-at-least-32-chars

# Required: BetterAuth session signing key (>=32 chars in production)
CONFIG_WATCH_AUTH_SECRET=dev-only-auth-secret-change-me-in-production-at-least-32-chars

# Required: Public URL of the control plane (used for auth redirects and CORS)
CONFIG_WATCH_AUTH_BASE_URL=http://localhost:8082

# CORS: Trusted origins for the dashboard (comma-separated)
CONFIG_WATCH_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8082

# Optional: Require admin approval for new sign-ups (default: true)
# CONFIG_WATCH_AUTH_REQUIRE_APPROVAL=true

# Optional: Admin API secret (falls back to CONTROL_PLANE_SECRET if not set)
# CONFIG_WATCH_AUTH_ADMIN_API_SECRET=

# Optional: OAuth providers
# CONFIG_WATCH_AUTH_GITHUB_CLIENT_ID=
# CONFIG_WATCH_AUTH_GITHUB_CLIENT_SECRET=
# CONFIG_WATCH_AUTH_GOOGLE_CLIENT_ID=
# CONFIG_WATCH_AUTH_GOOGLE_CLIENT_SECRET=

# Optional: GitHub personal access token for private repo access
# CONFIG_WATCH_GITHUB_TOKEN=

# Optional: Listen address (default: 127.0.0.1:8082)
# CONFIG_WATCH_BIND_ADDR=127.0.0.1:8082

# Optional: Event broadcast mode ("Local" or "Postgres", default: Local)
# CONFIG_WATCH_BROADCAST_MODE=Local

# ── Agent ─────────────────────────────────────────────────────────────

# Required: Unique agent ID (UUID)
CONFIG_WATCH_AGENT_ID=00000000-0000-0000-0000-000000000001

# Required: Environment label
CONFIG_WATCH_ENVIRONMENT=development

# Required: Control plane base URL (must be https:// if tls_required=true)
CONFIG_WATCH_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8082

# Required: Enrollment token for initial registration
CONFIG_WATCH_ENROLLMENT_TOKEN=dev-only-secret-change-me-in-production-at-least-32-chars

# Optional: Disable TLS requirement for local dev (default: true)
CONFIG_WATCH_TLS_REQUIRED=false

# Optional: Agent query API listen address (default: 127.0.0.1:9090)
# CONFIG_WATCH_AGENT_API_BIND_ADDR=0.0.0.0:9090

# Optional: HMAC secret for agent query API auth (empty = no auth, only safe on localhost)
# CONFIG_WATCH_AGENT_API_SECRET=

# Optional: Enable WebSocket tunnel to control plane (default: true)
# CONFIG_WATCH_TUNNEL_ENABLED=true

# Optional: Watcher backend — "auto" detects NFS, "poll" forces polling, "inotify" forces native (default: auto)
# CONFIG_WATCH_WATCH_MODE=auto

# Optional: Poll interval in seconds when using PollWatcher (default: 2)
# CONFIG_WATCH_POLL_INTERVAL_SECS=2

# ── Logging ───────────────────────────────────────────────────────────

RUST_LOG=info,config_agent=debug,config_control_plane=debug